table SalesData
	lineageTag: 86a94306-cd82-41f9-9f01-d424b1ab75c2

	measure 'Total Sales' = SUM(SalesData[Sales])
		lineageTag: f89bd340-af84-4d01-8be7-442312532557

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure minod = MIN(SalesData[Order Date])
		formatString: General Date
		lineageTag: d8b02c47-8485-446b-9830-734a3c6631e1

	measure maxod = MAX(SalesData[Order Date])
		formatString: General Date
		lineageTag: 574038f1-53e5-484f-b86d-eb3384b1c1dd

	measure minshid = min(SalesData[Ship Date])
		formatString: General Date
		lineageTag: 4a74a31f-e768-450b-8a04-d794520f3d6a

	measure maxshp = max(SalesData[Ship Date])
		formatString: General Date
		lineageTag: 32da766d-87fc-4555-82a9-02676366a6e0

	measure 'Total Sales(YTD)' = COALESCE(CALCULATE([Total Sales],DATESYTD('Calendar'[Date])),0)
		lineageTag: b1acbea6-33d4-46c7-839f-dd08d9220048

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales(QTD)' = CALCULATE([Total Sales],DATESQTD('Calendar'[Date]))
		lineageTag: 269e3fc0-8ead-4bd2-abfb-880f2690330a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales(MTD)' = CALCULATE([Total Sales],DATESMTD('Calendar'[Date]))
		lineageTag: 6dfe08cc-9c03-4900-b700-dfd20585ef8a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales(Last Year)' = CALCULATE([Total Sales],SAMEPERIODLASTYEAR('Calendar'[Date]))
		lineageTag: edb8996b-1592-41bc-9ab3-411246e54ad8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YOY Growth%' = COALESCE(DIVIDE([Total Sales]-[Total Sales(Last Year)],[Total Sales(Last Year)]),0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b0c52cf1-3469-4bc8-a4aa-05872b8aac3f

	measure Ranks = ```
			if(ISINSCOPE(SalesData[Product Name]),
			RANKX(ALL(SalesData[Product Name]),[Total Sales],,DESC,Dense))
			
			```
		formatString: 0
		lineageTag: 8315d65d-6810-4b1a-940f-ea4206c7d810

	measure YoyCLR = IF([YOY Growth%]<=0,"red","green")
		lineageTag: 2c584694-b9e4-4aa6-a575-2413a3b8d9b1

	measure 'Total Customers' = DISTINCTCOUNT(SalesData[Customer ID])
		formatString: 0
		lineageTag: 620d6d38-b825-4934-b7bc-b5e98035c631

	measure 'Total Qty Sold' = SUM(SalesData[Quantity])
		formatString: 0
		lineageTag: 7562025c-0af4-44e7-b87f-3485194ea570

	measure 'Avg.OrderValue' = AVERAGEX(SalesData,[Total Sales])
		lineageTag: 0866eaff-6c15-4c7c-b890-b7c06286c2f9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Profit' = sum(SalesData[Profit])
		lineageTag: 02d39255-afee-4020-a884-306883197f84

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales(Next Year)' = CALCULATE([Total Sales],NEXTYEAR('Calendar'[Date]))
		lineageTag: bd6f7337-f737-4793-85a8-9a40eb2b59d6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last 3 months Sales' = CALCULATE([Total Sales],DATESINPERIOD('Calendar'[Date],max('Calendar'[Date]),-3,DAY))
		lineageTag: d2456621-ebae-4af0-9f1f-03f648759883

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Last 3 months Sales datesbetween' = CALCULATE([Total Sales],DATESBETWEEN('Calendar'[Date],max('Calendar'[Date])-2,max('Calendar'[Date])))
		lineageTag: 9910c883-e7a2-42ce-80e1-bd935d5e613c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'total sales running' = CALCULATE([Total Sales],max('Calendar'[Date])>='Calendar'[Date])
		lineageTag: 6f3b1d16-a6c0-43bd-8256-42ff75647b4b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'TOTAL YTD' = TOTALYTD([Total Sales],'Calendar'[Date])
		lineageTag: 3ab98d7d-2765-4ea6-931e-78d5934c8122

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure KEEPFILTER = CALCULATE([Total Sales],KEEPFILTERS('Calendar'[Year]=2023))
		lineageTag: 307bc1fd-0e69-4dc9-b132-01645ae030a6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TREATAS = CALCULATE([Total Sales],TREATAS({"JANUARY","FEBRUARY"},'Calendar'[Month_Name]))
		lineageTag: 55991753-f503-412c-8abf-8c675ca2a60b

