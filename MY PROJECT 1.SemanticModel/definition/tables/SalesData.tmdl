	column 'Customer Age Group' = ```
			
			var ageslab=DATEDIFF(SalesData[Customer DoB],TODAY(),YEAR)
			return 
			 if(and(ageslab>=5,ageslab<=10),"Kids",if(ageslab<=17,"Teens",if(ageslab<=24,"Young Adults",if(ageslab<=34,"Adults",if(ageslab<=54,"Middle-aged Adults",if(ageslab>=55,"Seniors"))))))
			```
		lineageTag: a5813aa3-9e3d-4195-b955-5cd1edaf4d92
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

